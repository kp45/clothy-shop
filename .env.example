# Backend environment variables.
# Copy to `.env` for local use, and configure same keys in Railway service variables.

# Required: PostgreSQL connection URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/clothy_db

# Optional but recommended: forward uploaded images to Hostinger
HOSTINGER_UPLOAD_URL=https://your-domain.com/path/upload.php
HOSTINGER_UPLOAD_TOKEN=replace-me
HOSTINGER_UPLOAD_FIELD=image
HOSTINGER_PUBLIC_BASE_URL=https://your-domain.com
HOSTINGER_UPLOAD_TIMEOUT=60
